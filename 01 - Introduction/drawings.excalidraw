      "customData": {
        "generationData": {
          "status": "done",
          "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Minimalist Landing Page</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');\n        body {\n            font-family: 'Inter', sans-serif;\n        }\n    </style>\n</head>\n<body class=\"bg-white text-gray-800\">\n    <div class=\"container mx-auto px-4 py-8\">\n        <header class=\"flex justify-between items-center mb-16\">\n            <div class=\"text-2xl font-bold\">Logo</div>\n            <nav>\n                <ul class=\"flex space-x-6\">\n                    <li><a href=\"#\" class=\"hover:text-gray-600\">Home</a></li>\n                    <li><a href=\"#\" class=\"hover:text-gray-600\">About</a></li>\n                    <li><a href=\"#\" class=\"hover:text-gray-600\">Contact</a></li>\n                </ul>\n            </nav>\n        </header>\n\n        <main class=\"grid grid-cols-1 md:grid-cols-2 gap-16 items-center\">\n            <div>\n                <h1 class=\"text-5xl font-bold mb-6\">Minimalist Design</h1>\n                <p class=\"text-xl mb-8\">Create beautiful, functional websites with our minimalist approach to design.</p>\n                <button class=\"bg-black text-white px-8 py-3 rounded-full hover:bg-gray-800 transition duration-300\">Get Started</button>\n            </div>\n            <div class=\"aspect-w-16 aspect-h-9\">\n                <img src=\"https://source.unsplash.com/random/800x600?minimalist\" alt=\"Minimalist design\" class=\"object-cover rounded-lg shadow-lg\">\n            </div>\n        </main>\n\n        <section class=\"mt-24\">\n            <h2 class=\"text-3xl font-bold mb-8 text-center\">Our Services</h2>\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n                <div class=\"bg-gray-100 p-6 rounded-lg\">\n                    <h3 class=\"text-xl font-semibold mb-4\">Web Design</h3>\n                    <p>Create stunning websites that capture your brand's essence.</p>\n                </div>\n                <div class=\"bg-gray-100 p-6 rounded-lg\">\n                    <h3 class=\"text-xl font-semibold mb-4\">UX/UI Design</h3>\n                    <p>Craft intuitive user experiences that delight your audience.</p>\n                </div>\n                <div class=\"bg-gray-100 p-6 rounded-lg\">\n                    <h3 class=\"text-xl font-semibold mb-4\">Brand Identity</h3>\n                    <p>Develop a cohesive visual language for your brand.</p>\n                </div>\n            </div>\n        </section>\n\n        <footer class=\"mt-24 text-center text-gray-600\">\n            <p>&copy; 2023 Minimalist Design. All rights reserved.</p>\n        </footer>\n    </div>\n</body>\n</html>"
        }
      }
