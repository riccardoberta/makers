    },
    {
      "id": "CS0Db8DpBzArvWh3LrEEG",
      "type": "text",
      "x": -574.0138837189082,
      "y": 1998.890002902385,
      "width": 559.41259765625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEy",
      "roundness": null,
      "seed": 985026813,
      "version": 591,
      "versionNonce": 1776330205,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737370003849,
      "link": null,
      "locked": false,
      "text": "Standard proliferation in IoT arises from the existence of numerous,\noften incompatible standards developed by different organizations and\nindustries. This lack of uniformity hinders interoperability between\ndevices, complicates integration, and slows down the adoption of IoT\nsolutions on a global scale.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Standard proliferation in IoT arises from the existence of numerous, often incompatible standards developed by different organizations and industries. This lack of uniformity hinders interoperability between devices, complicates integration, and slows down the adoption of IoT solutions on a global scale.",
      "autoResize": false,
      "lineHeight": 1.25
    },
