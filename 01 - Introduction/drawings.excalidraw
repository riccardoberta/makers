    {
      "id": "SrAwE5qHMmB4mana1KPt1",
      "type": "text",
      "x": 1970.5722579341827,
      "y": 962.3319180705878,
      "width": 1545.39111328125,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDt",
      "roundness": null,
      "seed": 775811699,
      "version": 7,
      "versionNonce": 266109811,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1736347231947,
      "link": null,
      "locked": false,
      "text": "Cloud computing refers to the delivery of computing services, including storage, servers, databases, software, and more, over the internet. Instead of owning and maintaining physical infrastructure, \nindividuals and organizations can use cloud services on-demand and pay for only what they use.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cloud computing refers to the delivery of computing services, including storage, servers, databases, software, and more, over the internet. Instead of owning and maintaining physical infrastructure, \nindividuals and organizations can use cloud services on-demand and pay for only what they use.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Yc2jPQndnoYD-KzTHoVWf",
      "type": "text",
      "x": 2695.3460179409353,
      "y": 1030.7599297411123,
      "width": 559.41259765625,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDu",
      "roundness": null,
      "seed": 1025709373,
      "version": 970,
      "versionNonce": 1011781533,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737369450448,
      "link": null,
      "locked": false,
      "text": "Cloud computing refers to the delivery of computing services (storage,\nservers, databases, software, and more) over the internet. Instead of\nowning and maintaining physical infrastructure, it is possible to use\nservices on-demand and pay for only what it is used.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cloud computing refers to the delivery of computing services (storage, servers, databases, software, and more) over the internet. Instead of owning and maintaining physical infrastructure, it is possible to use services on-demand and pay for only what it is used.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "IzxZn_xNuvjebF1sm4qQV",
      "type": "text",
      "x": 2626.301915896182,
      "y": 1416.1494335026862,
      "width": 559.41259765625,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
