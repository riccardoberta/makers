    },
    {
      "id": "WbLpN3GraNkuCwZy5DhMb",
      "type": "text",
      "x": 2691.4114476284353,
      "y": 1371.8392724301557,
      "width": 559.41259765625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDw",
      "roundness": null,
      "seed": 322877395,
      "version": 1117,
      "versionNonce": 1478126941,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737369535708,
      "link": null,
      "locked": false,
      "text": "Fog computing is a distributed computing paradigm that extends cloud\ncomputing to the edge of the network, closer to the data sources. It\naims to reduce latency and network congestion by processing data\nlocally, in nearby edge devices or fog nodes, rather than transmitting it\nto a remote cloud.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fog computing is a distributed computing paradigm that extends cloud computing to the edge of the network, closer to the data sources. It aims to reduce latency and network congestion by processing data locally, in nearby edge devices or fog nodes, rather than transmitting it to a remote cloud.",
      "autoResize": false,
      "lineHeight": 1.25
    },
