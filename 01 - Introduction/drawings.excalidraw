      "isDeleted": true,
      "boundElements": [],
      "updated": 1737369202405,
      "link": null,
      "locked": false,
      "text": "a network of physical devices embedded with sensors, actuators,\nsoftware and connectivity that enable real objects to collect data and\nact on the environment. These devices provides automation, monitoring,\nand control. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "a network of physical devices embedded with sensors, actuators, software and connectivity that enable real objects to collect data and act on the environment. These devices provides automation, monitoring, and control. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
