    {
      "id": "u9ZkPP8nwsH-11zUweEyc",
      "type": "text",
      "x": 585.0880301339284,
      "y": 379.248046875,
      "width": 559.6366315569194,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 361140765,
      "version": 933,
      "versionNonce": 258855261,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737369204460,
      "link": "https://www.comparitech.com/internet-providers/iot-statistics/",
      "locked": false,
      "text": "Key statistics:  \n\n1. Number devices, as of 2023, there are approximately 16.7 billion IoT\ndevices worldwide, which is more than twice the number of people on\nEarth. This number is expected to grow to over 27 billion by 2025\n\n2. Market Growth, the global IoT market was valued at $662.21 billion\nin 2023 and is projected to reach around $3.3 trillion by 2030\n\n3. Smart Home Devices, in 2022, 857 million smart home devices were\nshipped globally. This number is expected to increase to 1.09 billion by\n2027",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Key statistics:  \n\n1. Number devices, as of 2023, there are approximately 16.7 billion IoT devices worldwide, which is more than twice the number of people on Earth. This number is expected to grow to over 27 billion by 2025\n\n2. Market Growth, the global IoT market was valued at $662.21 billion in 2023 and is projected to reach around $3.3 trillion by 2030\n\n3. Smart Home Devices, in 2022, 857 million smart home devices were shipped globally. This number is expected to increase to 1.09 billion by 2027",
      "autoResize": false,
      "lineHeight": 1.25
    },
