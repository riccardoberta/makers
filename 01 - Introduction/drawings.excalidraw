    {
      "id": "flMOgzYI2KgNRi3fMKaaE",
      "type": "text",
      "x": 862.5928113191467,
      "y": 2631.720360045242,
      "width": 559.41259765625,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bG0",
      "roundness": null,
      "seed": 53729043,
      "version": 1031,
      "versionNonce": 995921373,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737370273147,
      "link": null,
      "locked": false,
      "text": "Consider an IoT system called \"My Office,\" where a gateway\naggregates data from multiple sensors and transmits it to the cloud\nvia an access point, allowing end-users and applications to access and\ncontrol the system seamlessly.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Consider an IoT system called \"My Office,\" where a gateway aggregates data from multiple sensors and transmits it to the cloud via an access point, allowing end-users and applications to access and control the system seamlessly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
