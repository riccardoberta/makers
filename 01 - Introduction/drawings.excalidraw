    {
      "id": "YoAeSXc2amryU7bnPeqcP",
      "type": "text",
      "x": 912.4421760976479,
      "y": 1957.8483362357185,
      "width": 253.14132345639757,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
