    {
      "id": "pr7nB89aN1lYukuPboAM1",
      "type": "text",
      "x": 1603.2480836489835,
      "y": 1236.642058782082,
      "width": 555.9526890118916,
      "height": 119.25781249999997,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBu",
      "roundness": null,
      "seed": 28797107,
      "version": 719,
      "versionNonce": 2074965693,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1737369871228,
      "link": null,
      "locked": false,
      "text": "The growth in IoT is explosive, impressive and unsustainable under\ncurrent architectural approaches \n- latency, network bandwidth, reliability and security cannot be\naddressed in cloud-only models  \n- fog computing adds a hierarchy of elements between cloud and\ndevices",
      "fontSize": 15.901041666666664,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The growth in IoT is explosive, impressive and unsustainable under current architectural approaches \n- latency, network bandwidth, reliability and security cannot be addressed in cloud-only models  \n- fog computing adds a hierarchy of elements between cloud and devices",
      "autoResize": false,
      "lineHeight": 1.25
    },
